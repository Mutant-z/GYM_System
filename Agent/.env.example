APP_NAME=gym-agent
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_LOG_LEVEL=INFO
APP_CORS_ORIGINS=*

LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=gym-agent
LANGSMITH_ENDPOINT=

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_SECONDS=60
DEEPSEEK_MAX_RETRIES=3

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=bge-m3
OLLAMA_TIMEOUT_SECONDS=60

MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_DATABASE=default
MILVUS_COLLECTION=gym_agent_docs
MILVUS_DIMENSION=1024

REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_KEY_PREFIX=agent
REDIS_HISTORY_TTL_SECONDS=86400
REDIS_ANSWER_TTL_SECONDS=3600
REDIS_RETRIEVAL_TTL_SECONDS=3600
REDIS_EMBEDDING_TTL_SECONDS=604800

RAG_TOP_K=4
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_MIN_SCORE=0.75
RAG_MAX_CONTEXT_CHARS=6000
RAG_SUMMARY_ENABLED=true

DATA_DIR=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed
INGEST_LOCK_TTL_SECONDS=1800

JAVA_BACKEND_BASE_URL=http://localhost:8080/api
ENABLE_STREAMING=true
ENABLE_TOOL_CALLING=true

MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_DATABASE=gym_system
MYSQL_USERNAME=root
MYSQL_PASSWORD=
MYSQL_CHARSET=utf8mb4
MYSQL_POOL_SIZE=5
MYSQL_MAX_OVERFLOW=10
MYSQL_POOL_TIMEOUT_SECONDS=30
MYSQL_POOL_RECYCLE_SECONDS=1800
MYSQL_ECHO=false
